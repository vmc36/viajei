# Copy this file to `.env.local` and fill in the values.
# NEVER commit your real .env.local file.

ANTHROPIC_API_KEY=

# Optional: hard cap on tokens (input + output) spent across all requests
# in a rolling 24h window. Leave empty to disable. Resets in-memory at process restart.
ANTHROPIC_DAILY_TOKEN_BUDGET=

# Optional: Pexels API Key for attraction photos.
# Create a free key at https://www.pexels.com/api/ and paste it below.
# If empty, the itinerary still works — it just renders without photos.
PEXELS_API_KEY=
